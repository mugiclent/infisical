# Copy this file to .env for local development.
# In production these values come from GitHub Actions secrets — never commit .env.

# ─── Encryption (NEVER change after first run — all secrets become unrecoverable) ───
ENCRYPTION_KEY=
AUTH_SECRET=

# Generate fresh values with:
#   ENCRYPTION_KEY: openssl rand -hex 16
#   AUTH_SECRET:    openssl rand -base64 32

# ─── Database ─────────────────────────────────────────────────────────────────
# Uses the shared katisha postgres container on katisha-net.
# A dedicated 'infisical' database must exist — the deploy pipeline creates it.
DB_CONNECTION_URI=postgres://infisical:INFISICAL_DB_PASSWORD@db:5432/infisical

# ─── Redis ────────────────────────────────────────────────────────────────────
# Uses the shared katisha redis container on katisha-net.
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Must exactly match the public URL — affects magic links and OAuth redirects.
SITE_URL=https://vault.katisha.online

# ─── SMTP (required for magic-link / email login) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── OAuth SSO (optional) ─────────────────────────────────────────────────────
CLIENT_ID_GOOGLE_LOGIN=
CLIENT_SECRET_GOOGLE_LOGIN=

CLIENT_ID_GITHUB_LOGIN=
CLIENT_SECRET_GITHUB_LOGIN=

CLIENT_ID_GITLAB_LOGIN=
CLIENT_SECRET_GITLAB_LOGIN=

# ─── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=

OTEL_TELEMETRY_COLLECTION_ENABLED=false
OTEL_EXPORT_TYPE=prometheus
OTEL_EXPORT_OTLP_ENDPOINT=
OTEL_OTLP_PUSH_INTERVAL=
